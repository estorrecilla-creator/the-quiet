ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Opcional: para buscar vídeo libre de derechos en vez de generar portadas
# con IA (gratis, aprobación instantánea): https://www.pexels.com/api/
PEXELS_API_KEY=...

# Opcional: segunda fuente de vídeo libre de derechos, se usa como
# respaldo si Pexels no encuentra nada para una búsqueda (gratis,
# aprobación instantánea): https://pixabay.com/api/docs/
PIXABAY_API_KEY=...

# Opcional: tercera fuente de vídeo libre de derechos, se usa como
# respaldo si Pexels y Pixabay no encuentran nada (gratis, pero hay que
# pedirla por email a team@coverr.co): https://api.coverr.co/docs/start/
COVERR_API_KEY=...

# Opcional: se usan para rellenar los metadatos finales del audio
# (productor, editorial, copyright y copyright fonográfico) — si no las
# pones, se usa el nombre del artista de cada tema como valor por defecto.
RELEASE_PUBLISHER=Neural Void MUSIC
RELEASE_COPYRIGHT_HOLDER=Tu Nombre

# Solo hacen falta si vas a usar src/meta_uploader.py (Facebook/Instagram)
PAGE_ID=...
PAGE_ACCESS_TOKEN=...
IG_USER_ID=...
